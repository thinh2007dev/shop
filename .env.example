# Copy file này thành .env.local rồi điền key thật
# Supabase Dashboard -> Project Settings -> API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-public-key

# Service role key (BÍ MẬT - chỉ dùng ở server, KHÔNG có prefix NEXT_PUBLIC)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key

# ============================================
# SePay - tự dò giao dịch (KHÔNG cần webhook)
# Server tự gọi SePay API để kiểm tra tiền về khi khách bấm kiểm tra.
# Lấy token: SePay -> Công ty -> Cấu hình -> API Access (User API Token)
# ============================================
NEXT_PUBLIC_SEPAY_BANK=MBBank
NEXT_PUBLIC_SEPAY_ACCOUNT=0123456789
NEXT_PUBLIC_SEPAY_ACCOUNT_NAME=NGUYEN VAN A
SEPAY_API_TOKEN=your-sepay-user-api-token


