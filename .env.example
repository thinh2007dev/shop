# Copy file này thành .env.local rồi điền key thật
# Supabase Dashboard -> Project Settings -> API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-public-key

# Service role key (BÍ MẬT - chỉ dùng ở server, KHÔNG có prefix NEXT_PUBLIC)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key

# ============================================
# Thanh toán: QR VietQR để hiển thị mã QR cho khách.
# Sửa thông tin ngân hàng nhận tiền trực tiếp trong lib/sepay.ts
# (BANK_ID, SEPAY_ACCOUNT, SEPAY_ACCOUNT_NAME).
# ============================================

# ============================================
# Tự động nhận tiền qua SePay webhook.
# Đăng ký SePay (my.sepay.vn), liên kết bank, tạo Webhook:
#   - URL: https://<domain>/api/webhook/sepay
#   - Xác thực: API Key (Header) -> đặt trùng giá trị dưới đây
# Tự đặt 1 chuỗi ngẫu nhiên dài, giữ bí mật.
# ============================================
SEPAY_WEBHOOK_API_KEY=doi-thanh-1-chuoi-ngau-nhien-dai-bi-mat


