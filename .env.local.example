# Copy file này thành .env.local rồi điền key thật từ Supabase
# Supabase Dashboard -> Project Settings -> API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-public-key

# Service role key (BÍ MẬT - chỉ dùng ở server, KHÔNG có prefix NEXT_PUBLIC)
# Dùng cho auth (đăng ký/đăng nhập) vì customers table bật RLS
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key

# ============================================
# SePay - nhận tiền tự động qua webhook
# Dashboard: https://my.sepay.vn
# ============================================
# Thông tin tài khoản nhận tiền (dùng để sinh QR VietQR)
NEXT_PUBLIC_SEPAY_BANK=MBBank          # mã ngân hàng theo SePay (vd: MBBank, ACB, Vietcombank)
NEXT_PUBLIC_SEPAY_ACCOUNT=0123456789   # số tài khoản nhận tiền
NEXT_PUBLIC_SEPAY_ACCOUNT_NAME=NGUYEN VAN A  # tên chủ tài khoản (không dấu)

# Token bảo vệ webhook. Vào SePay -> Webhooks -> đặt "Authorization: Apikey <token>"
# rồi điền đúng token đó vào đây để verify request đến từ SePay.
SEPAY_WEBHOOK_TOKEN=your-random-secret-token
